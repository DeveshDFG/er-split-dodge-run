# Reads GLOBAL_CSPcKeyConfig RVA from libER symbols/singletons.csv.
# Writes native/build/generated/cspc_key_config_symbols.generated.hpp

function(er_split_decimal_to_hex dec_var hex_var)
    set(_n "${${dec_var}}")
    if(_n EQUAL 0)
        set(${hex_var} "0" PARENT_SCOPE)
        return()
    endif()
    set(_digits "0123456789abcdef")
    set(_hex "")
    while(_n GREATER 0)
        math(EXPR _digit "${_n} & 15")
        math(EXPR _n "${_n} >> 4")
        string(SUBSTRING "${_digits}" ${_digit} 1 _ch)
        set(_hex "${_ch}${_hex}")
    endwhile()
    set(${hex_var} "${_hex}" PARENT_SCOPE)
endfunction()

function(er_split_parse_rva_token token out_dec_var)
    string(STRIP "${token}" _token)
    if(_token MATCHES "^0[xX]([0-9a-fA-F]+)$")
        set(_hex "${CMAKE_MATCH_1}")
        set(_dec 0)
        string(LENGTH "${_hex}" _len)
        math(EXPR _len "${_len} - 1")
        foreach(_i RANGE ${_len} 0)
            string(SUBSTRING "${_hex}" ${_i} 1 _ch)
            if(_ch MATCHES "[0-9]")
                set(_digit "${_ch}")
            elseif(_ch MATCHES "[a-f]")
                string(ASCII _ord "${_ch}")
                math(EXPR _digit "${_ord} - 87")
            elseif(_ch MATCHES "[A-F]")
                string(ASCII _ord "${_ch}")
                math(EXPR _digit "${_ord} - 55")
            else()
                set(_digit -1)
            endif()
            if(_digit LESS 0)
                set(_dec "")
                break()
            endif()
            math(EXPR _dec "(${_dec} * 16) + ${_digit}")
        endforeach()
        if(_dec STREQUAL "")
            return()
        endif()
        set(${out_dec_var} "${_dec}" PARENT_SCOPE)
        return()
    endif()
    if(_token MATCHES "^[0-9]+$")
        set(${out_dec_var} "${_token}" PARENT_SCOPE)
    endif()
endfunction()

function(er_split_generate_cspc_symbols_header liber_root out_header)
    set(_fallback_dec "64347816")
    set(_rva_dec "")
    set(_rva_source "fallback")

    if(DEFINED ENV{ER_SPLIT_CSPC_KEY_CONFIG_RVA})
        er_split_parse_rva_token("$ENV{ER_SPLIT_CSPC_KEY_CONFIG_RVA}" _env_dec)
        if(_env_dec)
            set(_rva_dec "${_env_dec}")
            set(_rva_source "ER_SPLIT_CSPC_KEY_CONFIG_RVA")
        endif()
    endif()

    if(NOT _rva_dec)
        set(_local_rva "${CMAKE_CURRENT_SOURCE_DIR}/cspc_key_config_rva.txt")
        if(EXISTS "${_local_rva}")
            file(READ "${_local_rva}" _local_content)
            string(REPLACE "\r" "" _local_content "${_local_content}")
            string(REPLACE "\n" ";" _local_lines "${_local_content}")
            foreach(_line IN LISTS _local_lines)
                string(STRIP "${_line}" _line)
                if(_line STREQUAL "" OR _line MATCHES "^#")
                    continue()
                endif()
                er_split_parse_rva_token("${_line}" _local_dec)
                if(_local_dec)
                    set(_rva_dec "${_local_dec}")
                    set(_rva_source "${_local_rva}")
                    break()
                endif()
            endforeach()
        endif()
    endif()

    if(NOT _rva_dec)
        set(_csv "")
        if(liber_root AND EXISTS "${liber_root}/symbols/singletons.csv")
            set(_csv "${liber_root}/symbols/singletons.csv")
        elseif(EXISTS "${CMAKE_CURRENT_SOURCE_DIR}/libER/libER/symbols/singletons.csv")
            set(_csv "${CMAKE_CURRENT_SOURCE_DIR}/libER/libER/symbols/singletons.csv")
        endif()
        if(_csv)
            file(READ "${_csv}" _csv_content)
            string(REGEX MATCH "\"GLOBAL_CSPcKeyConfig\",\"([0-9]+)\"" _ "${_csv_content}")
            if(CMAKE_MATCH_1)
                set(_rva_dec "${CMAKE_MATCH_1}")
                set(_rva_source "${_csv}")
            endif()
        endif()
    endif()

    if(NOT _rva_dec)
        set(_rva_dec "${_fallback_dec}")
        set(_rva_source "fallback")
    endif()

    message(STATUS "cspc symbols: GLOBAL_CSPcKeyConfig RVA=${_rva_dec} (from ${_rva_source})")

    er_split_decimal_to_hex(_rva_dec _rva_hex)
    file(WRITE "${out_header}" "// Generated by cmake/generate_cspc_symbols.cmake — do not edit.
#pragma once

#include <cstdint>

namespace cspc_key_config_symbols {

inline constexpr std::uintptr_t kGlobalCspcKeyConfigRva = ${_rva_dec}u; // 0x${_rva_hex}

} // namespace cspc_key_config_symbols
")
endfunction()
